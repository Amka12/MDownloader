<Window x:Class="MDownloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:wpf="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="Mega Downloader"
        Height="1080" Width="1920"
        Background="#1E1E1E"
        Foreground="White"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Стили для кнопок (Modern Dark Style) -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#333333" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007ACC" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стили для TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="Margin" Value="0,5,0,10" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Верхняя панель инструментов -->
            <RowDefinition Height="Auto" />
            <!-- Основная рабочая область (Плеер + Загрузчик) -->
            <RowDefinition Height="*" />
            <!-- Список файлов (Плейлист) -->
            <RowDefinition Height="250" />
        </Grid.RowDefinitions>

        <!-- ================= ВЕРХНЯЯ ПАНЕЛЬ ================= -->
        <Border Padding="10">
            <StackPanel Orientation="Horizontal" Background="#252526">
                <TextBlock Text="VIDEO MANAGER" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"
                           Margin="0,0,20,0" />

                <Button Content="📂 Открыть папку" Command="{Binding OpenFolderCommand}" />
                <Separator Width="1" Background="#555" Margin="10,5" />
                <TextBlock Text="Текущая папка:" VerticalAlignment="Center" Foreground="#AAA" />
                <TextBlock x:Name="LblFolderPath" Text="{Binding FolderPath}" VerticalAlignment="Center"
                           Margin="5,0,0,0"
                           Foreground="#007ACC" />
            </StackPanel>
        </Border>

        <!-- ================= ЦЕНТРАЛЬНАЯ ОБЛАСТЬ ================= -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <!-- Видео плеер (занимает все свободное место) -->
                <ColumnDefinition Width="*" />
                <!-- Панель загрузки YouTube (фиксированная ширина) -->
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- ВИДЕО ПЛЕЕР С ПАНЕЛЬЮ УПРАВЛЕНИЯ -->
            <Border Grid.Column="0" Background="Black" CornerRadius="5" BorderBrush="#333" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- VideoView от LibVLCSharp -->
                    <wpf:VideoView x:Name="VideoPlayerControl"
                                   Grid.Row="0"
                                   MediaPlayer="{Binding MediaPlayer}"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"/>

                    <!-- Панель управления -->
                    <Border Grid.Row="1" Background="#252526" Padding="15,10"
                            BorderBrush="#333" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Прогресс бар и время -->
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding CurrentTime}"
                                           Foreground="#AAA"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           FontFamily="Consolas" />

                                <Slider Grid.Column="1"
                                        Minimum="0"
                                        Maximum="{Binding Duration}"
                                        Value="{Binding CurrentPosition, Mode=TwoWay}"
                                        VerticalAlignment="Center"
                                        Background="#555"
                                        Foreground="#007ACC">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                            <i:InvokeCommandAction Command="{Binding SetDraggingCommand}" CommandParameter="True"/>
                                        </i:EventTrigger>
                                        <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                            <i:InvokeCommandAction Command="{Binding SetDraggingCommand}" CommandParameter="False"/>
                                            <i:InvokeCommandAction Command="{Binding SeekCommand}"
                                                                   CommandParameter="{Binding Value, RelativeSource={RelativeSource AncestorType=Slider}}"/>
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </Slider>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding TotalTime}"
                                           Foreground="#AAA"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0"
                                           FontFamily="Consolas" />
                            </Grid>

                            <!-- Кнопки управления -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                <!-- Play/Pause -->
                                <Button
                                    Content="{Binding IsPlaying, Converter={StaticResource BoolToPlayPauseIconConverter}}"
                                    Command="{Binding TogglePlayPauseCommand}"
                                    Style="{StaticResource MediaButton}" />

                                <!-- Stop -->
                                <Button Content="⏹"
                                        Command="{Binding StopCommand}"
                                        Style="{StaticResource MediaButton}" />

                                <!-- Разделитель -->
                                <Rectangle Width="1" Fill="#555" Margin="15,5" />

                                <!-- Volume -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <ToggleButton
                                        Content="{Binding IsMuted, Converter={StaticResource BoolToVolumeIconConverter}}"
                                        IsChecked="{Binding IsMuted}"
                                        Width="35" Height="35"
                                        FontSize="14"
                                        Background="#333"
                                        Foreground="White"
                                        Cursor="Hand"
                                        Margin="0,0,5,0">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Background" Value="#333333" />
                                                <Setter Property="Foreground" Value="White" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Cursor" Value="Hand" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#007ACC" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>

                                    <Slider Width="100"
                                            Minimum="0"
                                            Maximum="100"
                                            Value="{Binding Volume, Mode=TwoWay}"
                                            VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- 2. ПАНЕЛЬ ЗАГРУЗКИ YOUTUBE -->
            <Border Grid.Column="1" Background="#2D2D30" CornerRadius="5" Margin="10,0,0,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="YouTube Downloader" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" />

                    <TextBlock Text="Вставьте ссылку:" FontSize="12" Foreground="#AAA" />
                    <TextBox x:Name="TxtYoutubeUrl" Height="30" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Text="{Binding YoutubeUrl}"/>

                    <TextBlock Text="Качество:" FontSize="12" Foreground="#AAA" />
                    <ComboBox Margin="0,0,0,10" 
                              ItemsSource="{Binding QualityOptions}"
                              SelectedItem="{Binding SelectedQuality}"
                              SelectedIndex="0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Button x:Name="BtnDownload" Content="⬇ Скачать в папку" Height="35" FontSize="14"
                            FontWeight="Bold" Command="{Binding DownloadCommand}"/>

                    <!-- Прогресс бар и статус -->
                    <ProgressBar x:Name="DownloadProgress" Height="10" Margin="0,15,0,5" Minimum="0" Maximum="100"
                                 Value="{Binding DownloadProgress}" />
                    <TextBlock x:Name="LblDownloadStatus" Text="{Binding DownloadStatus}" FontSize="11" Foreground="#AAA"
                               HorizontalAlignment="Center" TextWrapping="Wrap"/>

                    <Border Background="#1E1E1E" CornerRadius="3" Margin="0,10,0,0" Padding="5">
                        <TextBlock Text="ℹ Видео автоматически добавится в плейлист после загрузки."
                                   FontSize="11"
                                   Foreground="#888"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ================= НИЖНЯЯ ПАНЕЛЬ (ПЛЕЙЛИСТ) ================= -->
        <Border Grid.Row="2" Background="#252526" BorderBrush="#333" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Заголовок списка -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,5">
                    <TextBlock Text="📁 Файлы в папке" FontWeight="Bold" VerticalAlignment="Center" />
                    <Button Content="⟳ Обновить" Padding="5,2" FontSize="10" Margin="10,0,0,0"
                            Command="{Binding RefreshListCommand}" />
                </StackPanel>

                <!-- Список файлов -->
                <ListView x:Name="LvFileList"
                          Grid.Row="1"
                          Background="#1E1E1E"
                          Foreground="LightGray"
                          BorderThickness="0"
                          SelectionMode="Single"
                          ItemsSource="{Binding VideoFiles}"
                          SelectedItem="{Binding SelectedVideo, Mode=TwoWay}">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseDoubleClick">
                            <i:InvokeCommandAction Command="{Binding PlayVideoCommand}"
                                                   CommandParameter="{Binding SelectedItem, ElementName=LvFileList}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="Padding" Value="8,5" />
                            <Setter Property="Margin" Value="2,1" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}"
                                                Margin="{TemplateBinding Margin}"
                                                CornerRadius="3"
                                                BorderBrush="Transparent"
                                                BorderThickness="0">
                                            <GridViewRowPresenter
                                                Content="{TemplateBinding Content}"
                                                Columns="{TemplateBinding GridView.ColumnCollection}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#007ACC" />
                                                <Setter Property="Foreground" Value="White" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#2D2D30" />
                                            </Trigger>
                                            <!-- Анимация при выделении -->
                                            <EventTrigger RoutedEvent="Selected">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ColorAnimation
                                                            Storyboard.TargetName="Bd"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#007ACC"
                                                            Duration="0:0:0.2" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Имя файла" Width="500" DisplayMemberBinding="{Binding Name}" />
                            <GridViewColumn Header="Размер" Width="100" DisplayMemberBinding="{Binding Size}" />
                            <GridViewColumn Header="Дата" Width="150" DisplayMemberBinding="{Binding Date}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Window>