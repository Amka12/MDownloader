<Application x:Class="MDownloader.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:MDownloader.Converters">
    <Application.Resources>
        <converters:BoolToPlayPauseIconConverter x:Key="BoolToPlayPauseIconConverter" />
        <converters:BoolToVolumeIconConverter x:Key="BoolToVolumeIconConverter" />

        <!-- Стили кнопок -->
        <Style TargetType="Button" x:Key="MediaButton">
            <Setter Property="Background" Value="#333333" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="45" />
            <Setter Property="Height" Value="45" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#007ACC" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для слайдера -->
        <ControlTemplate x:Key="SliderThumb" TargetType="Thumb">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Внешний круг -->
                <Ellipse x:Name="ThumbEllipse"
                         Width="16"
                         Height="16"
                         Fill="#007ACC"
                         Stroke="White"
                         StrokeThickness="2">
                    <Ellipse.Effect>
                        <DropShadowEffect BlurRadius="4" 
                                          ShadowDepth="0" 
                                          Opacity="0.3"/>
                    </Ellipse.Effect>
                </Ellipse>

                <!-- Внутренний круг -->
                <Ellipse Width="8"
                         Height="8"
                         Fill="White"
                         Opacity="0.5"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="ThumbEllipse" Property="Fill" Value="#0099FF"/>
                    <Setter TargetName="ThumbEllipse" Property="Width" Value="18"/>
                    <Setter TargetName="ThumbEllipse" Property="Height" Value="18"/>
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                    <Setter TargetName="ThumbEllipse" Property="Fill" Value="#005A9E"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="Slider" x:Key="VideoSeekBar">
            <Setter Property="Background" Value="#555555"/>
            <Setter Property="Foreground" Value="#007ACC"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <!-- Track -->
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{TemplateBinding Foreground}" 
                                                CornerRadius="2"
                                                Height="4"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>

                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{TemplateBinding Foreground}" 
                                                Opacity="0.3"
                                                CornerRadius="2"
                                                Height="4"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>

                                <Track.Thumb>
                                    <Thumb Template="{StaticResource SliderThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>